# instantvim's dedicated background Ghostty instance.
#
# This instance exists ONLY to host instantvim's quick terminal. It is
# launched hidden at login (see launchd/com.instantvim.qt.plist) and never
# shows a normal window or tab. Keeping it fully separate from your everyday
# Ghostty config/instance means:
#   - its `command` (the FIFO dispatcher) never appears in a normal window
#   - its quick-terminal keybind never collides with your own
#
# install.sh copies this file and substitutes __DISPATCH_SCRIPT__ with the
# absolute path to instantvim-dispatch.sh.
#
# NOTE: `config-default-files = false` is deliberately NOT set here — per
# Ghostty's own docs it's "a CLI-only configuration. Setting this in a
# configuration file will have no effect." It's passed as
# --config-default-files=false in launchd/com.instantvim.qt.plist instead,
# so this dedicated instance never picks up your everyday ~/.config/ghostty
# config on top of this one.

macos-hidden = always
initial-window = false
window-save-state = never
quick-terminal-autohide = false
quick-terminal-animation-duration = 0.2

command = __DISPATCH_SCRIPT__

# Internal-only toggle: Hammerspoon simulates this exact keystroke (see
# instantvim.spoon's config.qtToggleKeystroke) to show/hide this instance's
# quick terminal. It is not meant to be pressed by you directly, which is
# why it's bound to a key most keyboards lack (macOS can still synthesize
# it via CGEvent, which is all Hammerspoon needs).
keybind = global:f19=toggle_quick_terminal
